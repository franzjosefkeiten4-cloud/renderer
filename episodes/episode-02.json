  "dialogue": [
    {
      "scene_index": 0,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Eine Schreinerei. Nicht die aufgeräumte Art, die es in Magazinen gibt – die echte Art: Sägemehlatem, Öl und Harz, Werkzeug an der Wand in einer Ordnung, die nur Markus kennt.\n\nAuf der Werkbank: vier ausgedruckte A3-Blätter, nebeneinander gelegt. Die Zeichnungen. Eine Stelle ist markiert. Bleistiftkreis um eine Wandnische – ein einziges Fragezeichen daneben.\n\nMarkus zieht sein Telefon heraus. Er öffnet einen E-Mail-Entwurf: »Goedemiddag. Ik heb een vraag over de tekeningen. De boekenplank, de nis in de muur – de...«\n\nEr schaut auf den Satz. Löscht ihn.\n\nDann nimmt er das Telefon. Wählt."
    },
    {
      "scene_index": 1,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Das Freizeichnen. Einmal. Zweimal."
    },
    {
      "scene_index": 1,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "am Telefon, professionell",
      "type": "dialogue",
      "nl_text": "Met Jan van der Berg.",
      "ww_text": "Mit Jan van der Berg.",
      "de_text": "Jan van der Berg.",
      "has_reveal_button": false
    },
    {
      "scene_index": 1,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "am Telefon, konzentriert",
      "type": "dialogue",
      "nl_text": "Goedemiddag. Met Markus Weber.",
      "ww_text": "Guten·Morgen. Mit Markus Weber.",
      "de_text": "Guten Morgen. Markus Weber.",
      "has_reveal_button": false
    },
    {
      "scene_index": 1,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "am Telefon, sofortige Wärme",
      "type": "dialogue",
      "nl_text": "Markus! Goedemiddag. Goed nieuws?",
      "ww_text": "Markus! Guten·Morgen. Gut·Neuigkeit?",
      "de_text": "Markus! Guten Morgen. Gute Neuigkeiten?",
      "has_reveal_button": true
    },
    {
      "scene_index": 1,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "am Telefon",
      "type": "dialogue",
      "nl_text": "Ja. Ik heb de tekeningen. Ze zijn goed. Maar ik heb een vraag.",
      "ww_text": "Ja. Ich habe die Zeichnungen. Sie sind gut. Aber ich habe eine Frage.",
      "de_text": "Ja. Ich habe die Zeichnungen. Sie sind gut. Aber ich habe eine Frage.",
      "has_reveal_button": false
    },
    {
      "scene_index": 1,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "am Telefon",
      "type": "dialogue",
      "nl_text": "Zeg het maar.",
      "ww_text": "Sag es mal.",
      "de_text": "Sagen Sie ruhig.",
      "has_reveal_button": true
    },
    {
      "scene_index": 1,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "am Telefon, sucht nach Wort",
      "type": "dialogue",
      "nl_text": "De boekenplank. De nis in de muur. Hoe diep is de nis?",
      "ww_text": "Die Bücher·planke. Die Nische in der Mauer. Wie tief ist die Nische?",
      "de_text": "Das Bücherregal. Die Nische in der Wand. Wie tief ist die Nische?",
      "has_reveal_button": false
    },
    {
      "scene_index": 1,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "am Telefon",
      "type": "dialogue",
      "nl_text": "Ah. Dat weet ik niet uit mijn hoofd. Dat hangt af van de muur. Wil je even langskomen? Dan kunnen we het opmeten.",
      "ww_text": "Ah. Das weiß ich nicht auswendig. Das hängt von der Mauer ab. Willst du mal langskommen? Dann können wir es abmessen.",
      "de_text": "Ah. Das weiß ich nicht auswendig. Das hängt von der Wand ab. Möchten Sie kurz vorbeikommen? Dann können wir es ausmessen.",
      "has_reveal_button": true
    },
    {
      "scene_index": 1,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "am Telefon",
      "type": "dialogue",
      "nl_text": "Naar huis. Zaterdag? Marta is er dan. Ik stuur het adres.",
      "ww_text": "Nach Haus. Samstag? Marta ist da dann. Ich schicke die Adresse.",
      "de_text": "Nach Hause. Samstag? Marta ist dann da. Ich schicke Ihnen die Adresse.",
      "has_reveal_button": true
    },
    {
      "scene_index": 1,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "am Telefon, kurze Pause vor diesem Satz",
      "type": "dialogue",
      "nl_text": "En — de tekeningen kwamen een dag te laat. Dat spijt me.",
      "ww_text": "Und — die Zeichnungen kamen einen Tag zu spät. Das bereue ich.",
      "de_text": "Und — die Zeichnungen kamen einen Tag zu spät. Das tut mir leid.",
      "has_reveal_button": true
    },
    {
      "scene_index": 1,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "am Telefon",
      "type": "dialogue",
      "nl_text": "Dat is geen probleem.",
      "ww_text": "Das ist kein Problem.",
      "de_text": "Das ist kein Problem.",
      "has_reveal_button": false
    },
    {
      "scene_index": 1,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "am Telefon",
      "type": "dialogue",
      "nl_text": "Toch. Tot zaterdag.",
      "ww_text": "Trotzdem. Bis Samstag.",
      "de_text": "Trotzdem. Bis Samstag.",
      "has_reveal_button": false
    },
    {
      "scene_index": 1,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Das Gespräch ist beendet.\n\nMarkus schaut auf sein Telefon. Dann auf die Zeichnungen.\n\nEr nimmt seinen Bleistift. Schreibt neben das Fragezeichen:\n»zat. opmeten«"
    },
    {
      "scene_index": 2,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Eine Wohnstraße. Backsteinhäuser aus den Dreißigern, ein Platanenbaum nach dem anderen, Blätter schon halb weg.\n\nMarkus' Auto parkt. Er sitzt noch einen Moment. Kein Radio diesmal – er hat es nicht laufen lassen.\n\nEr schaut auf seine Uhr. Genau pünktlich."
    },
    {
      "scene_index": 2,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "öffnet die Tür, sein Haus macht ihn anders",
      "type": "dialogue",
      "nl_text": "Markus. Kom binnen.",
      "ww_text": "Markus. Komm innen.",
      "de_text": "Markus. Kommen Sie rein.",
      "has_reveal_button": false
    },
    {
      "scene_index": 2,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Ein kurzer Blick in den Flur: gerahmte Drucke, ein Garderobenspiegel, und – links an der Wand – ein langes, halbvolles Regal. Bücher quer und längs gestapelt, ein paar zu viele für den Platz.\n\nMarkus sieht das Regal. Er sagt nichts."
    },
    {
      "scene_index": 2,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "geht voran",
      "type": "dialogue",
      "nl_text": "De woonkamer is hier.",
      "ww_text": "Das Wohn·zimmer ist hier.",
      "de_text": "Das Wohnzimmer ist hier.",
      "has_reveal_button": false
    },
    {
      "scene_index": 3,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Der Wohnraum. Hohe Decken, guter Boden, Fenster auf den Garten. Und an der Wand zwischen den Fenstern: nichts. Eine glatte, blinde Wand. Zwei Meter vierzig breit, von Fensterleibung zu Fensterleibung.\n\nMorgenlicht fällt genau auf diese Wand."
    },
    {
      "scene_index": 3,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "zeigt auf die Wand",
      "type": "dialogue",
      "nl_text": "Dit is de muur. Hier komt ze.",
      "ww_text": "Das ist die Mauer. Hier kommt sie. [ze = de plank, femininum]",
      "de_text": "Das ist die Wand. Hier kommt das Regal hin.",
      "has_reveal_button": true
    },
    {
      "scene_index": 3,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "misst, notiert",
      "type": "dialogue",
      "nl_text": "Twee meter twaalf. De breedte?",
      "ww_text": "Zwei Meter zwölf. Die Breite?",
      "de_text": "Zwei Meter zwölf. Und die Breite?",
      "has_reveal_button": false
    },
    {
      "scene_index": 3,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "hält das Maßband, zeigt auf die Nische",
      "type": "dialogue",
      "nl_text": "Twee meter veertig, van muur tot muur. Maar de nis...",
      "ww_text": "Zwei Meter vierzig, von Mauer bis Mauer. Aber die Nische...",
      "de_text": "Zwei Meter vierzig, von Wand zu Wand. Aber die Nische...",
      "has_reveal_button": true
    },
    {
      "scene_index": 3,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "kniet, misst die Nische",
      "type": "dialogue",
      "nl_text": "Zesentwintig centimeter.",
      "ww_text": "Sechsundzwanzig Zentimeter.",
      "de_text": "Sechsundzwanzig Zentimeter.",
      "has_reveal_button": false
    },
    {
      "scene_index": 3,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "nickt",
      "type": "dialogue",
      "nl_text": "Precies wat ik dacht. Maar ik wou het zeker weten.",
      "ww_text": "Genau was ich dachte. Aber ich wollte es sicher wissen.",
      "de_text": "Genau was ich dachte. Aber ich wollte sichergehen.",
      "has_reveal_button": true
    },
    {
      "scene_index": 3,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Sie arbeiten eine Weile."
    },
    {
      "scene_index": 3,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "aus dem Flur, ruft rein",
      "type": "dialogue",
      "nl_text": "Jan?",
      "ww_text": "Jan?",
      "de_text": "Jan?",
      "has_reveal_button": false
    },
    {
      "scene_index": 3,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "ruft, ruhig",
      "type": "dialogue",
      "nl_text": "Hier. De woonkamer.",
      "ww_text": "Hier. Das Wohn·zimmer.",
      "de_text": "Hier. Das Wohnzimmer.",
      "has_reveal_button": false
    },
    {
      "scene_index": 3,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Schritte. Eine Tasche wird abgestellt. Dann erscheint sie im Türrahmen.\n\nMitte fünfzig. Sie schaut Markus sofort an, nicht mit Misstrauen – mit der unkomplizierten Neugier von jemandem, der einen Fremden in ihrem Wohnzimmer vorfindet."
    },
    {
      "scene_index": 3,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "stellt vor",
      "type": "dialogue",
      "nl_text": "Marta. Dit is Markus Weber. De schrijnwerker uit Kleve, die ik je had verteld.",
      "ww_text": "Marta. Das ist Markus Weber. Der Schreiner aus Kleve, von dem ich dir gesagt hatte.",
      "de_text": "Marta. Das ist Markus Weber. Der Schreiner aus Kleve, von dem ich dir erzählt habe.",
      "has_reveal_button": true
    },
    {
      "scene_index": 3,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "Hand ausgestreckt, direkt",
      "type": "dialogue",
      "nl_text": "Aangenaam.",
      "ww_text": "Angenehm. [= Angenehmheit; formale Begrüßung]",
      "de_text": "Aangenaam. – Angenehm. [Formale Begrüßung: »Freut mich.«]",
      "has_reveal_button": true
    },
    {
      "scene_index": 3,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "nimmt die Hand",
      "type": "dialogue",
      "nl_text": "Aangenaam.",
      "ww_text": "Angenehm.",
      "de_text": "Freut mich.",
      "has_reveal_button": false
    },
    {
      "scene_index": 3,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "zu Jan, praktisch",
      "type": "dialogue",
      "nl_text": "Zijn jullie al lang bezig?",
      "ww_text": "Sind ihr schon lang beschäftigt?",
      "de_text": "Seid ihr schon lange dabei?",
      "has_reveal_button": true
    },
    {
      "scene_index": 3,
      "speaker": "JAN",
      "speaker_role": "character",
      "type": "dialogue",
      "nl_text": "Nog maar net.",
      "ww_text": "Noch aber gerade.",
      "de_text": "Gerade erst angefangen.",
      "has_reveal_button": true
    },
    {
      "scene_index": 3,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "zu Markus, freundlich",
      "type": "dialogue",
      "nl_text": "Koffie?",
      "ww_text": "Kaffee?",
      "de_text": "Kaffee?",
      "has_reveal_button": false
    },
    {
      "scene_index": 3,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "dialogue",
      "nl_text": "Ja. Graag.",
      "ww_text": "Ja. Gerne.",
      "de_text": "Ja. Gerne.",
      "has_reveal_button": false
    },
    {
      "scene_index": 4,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Jan ist kurz raus – sein Telefon hatte vibriert, er hat sich in den Flur verzogen. »Een moment« – dieselbe Geste wie damals, bevor er das Telefonat mit dem zusje annahm.\n\nMarkus steht allein in dem Zimmer.\n\nEr schaut auf seine Notizbuchseite. Alles drauf, was er braucht.\n\nDann schaut er die Wand an. Stellt sich vor, wie sie wird: Eiche, vielleicht. Natürlich geölt. Die Nische eingebaut, statt ausgelassen. Das Licht, das morgens auf die Buckrücken fällt."
    },
    {
      "scene_index": 4,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Marta kommt mit zwei Tassen Kaffee. Stellt eine auf den Tisch. Eine hält sie. Sie tritt neben Markus. Schaut auch auf die Wand."
    },
    {
      "scene_index": 4,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "nicht zu Markus – eher für sich, die Wand betrachtend",
      "type": "dialogue",
      "nl_text": "Endelijk.",
      "ww_text": "Endlich.",
      "de_text": "Endlich.",
      "has_reveal_button": true
    },
    {
      "scene_index": 4,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "zu Markus, freundlich",
      "type": "dialogue",
      "nl_text": "Wordt het groot?",
      "ww_text": "Wird es groß?",
      "de_text": "Wird es groß?",
      "has_reveal_button": true
    },
    {
      "scene_index": 4,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "einen Moment, dann",
      "type": "dialogue",
      "nl_text": "...Groot?",
      "ww_text": "...Groß?",
      "de_text": "...Groß?",
      "has_reveal_button": false
    },
    {
      "scene_index": 4,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "macht eine Geste: Boden bis Decke",
      "type": "dialogue",
      "nl_text": "Van hier tot hier.",
      "ww_text": "Von hier bis hier.",
      "de_text": "Von hier bis hier.",
      "has_reveal_button": false
    },
    {
      "scene_index": 4,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "speaker_note": "zeigt nach oben",
      "type": "dialogue",
      "nl_text": "Ja. Van de vloer... ...tot het plafond.",
      "ww_text": "Ja. Von dem Boden... ...bis die Decke.",
      "de_text": "Ja. Vom Boden bis zur Decke.",
      "has_reveal_button": false
    },
    {
      "scene_index": 4,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "nickt, etwas leuchtet auf",
      "type": "dialogue",
      "nl_text": "Mooi. We hebben te veel boeken.",
      "ww_text": "Schön. Wir haben zu viele Bücher.",
      "de_text": "Schön. Wir haben zu viele Bücher.",
      "has_reveal_button": true
    },
    {
      "scene_index": 4,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "mit einem Lachen, leise – eher als Geständnis",
      "type": "dialogue",
      "nl_text": "Ik houd van boeken. Veel te veel, zegt Jan altijd.",
      "ww_text": "Ich halte von Büchern. Viel zu viel, sagt Jan immer.",
      "de_text": "Ich liebe Bücher. Viel zu sehr, sagt Jan immer.",
      "has_reveal_button": true
    },
    {
      "scene_index": 4,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "dialogue",
      "nl_text": "Ja.",
      "ww_text": "Ja.",
      "de_text": "Ja.",
      "has_reveal_button": false
    },
    {
      "scene_index": 4,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Ihr Telefon vibriert auf dem Tisch. Sie sieht drauf."
    },
    {
      "scene_index": 4,
      "speaker": "MARTA",
      "speaker_role": "character",
      "speaker_note": "einen Atemzug Pause, dann leicht – nicht genervt, nur beschäftigt",
      "type": "dialogue",
      "nl_text": "Mijn zusje. Altijd op het verkeerde moment.",
      "ww_text": "Mein Schwester·chen. Immer auf dem falschen Moment.",
      "de_text": "Meine Schwester. Immer im falschen Moment.",
      "has_reveal_button": true
    },
    {
      "scene_index": 4,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Sie nimmt das Telefon. Geht damit Richtung Küche."
    },
    {
      "scene_index": 4,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "inner_monologue",
      "de_text": "Mijn zusje.\n\nEr trinkt seinen Kaffee."
    },
    {
      "scene_index": 5,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Alles gemessen. Alles notiert. Markus schließt seine Tasche.\n\nJan begleitet ihn zur Tür. Marta ist noch am Telefon.\n\nIm Flur wieder das überfüllte Regal. Diesmal bleibt Markus einen kurzen Moment davor stehen. Er sieht jetzt, was er vorhin nur gestreift hat: Lyrik. Geschichte. Ein niederländisch-deutsches Wörterbuch – altes, abgegriffenes. Ganz unten, ohne Absicht verstaut."
    },
    {
      "scene_index": 5,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "draußen, ruhig",
      "type": "dialogue",
      "nl_text": "En? Alles duidelijk?",
      "ww_text": "Und? Alles deutlich/klar?",
      "de_text": "Und? Alles klar?",
      "has_reveal_button": true
    },
    {
      "scene_index": 5,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "dialogue",
      "nl_text": "Ja. Geen problemen.",
      "ww_text": "Ja. Keine Probleme.",
      "de_text": "Ja. Keine Probleme.",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "JAN",
      "speaker_role": "character",
      "type": "dialogue",
      "nl_text": "De nis?",
      "ww_text": "Die Nische?",
      "de_text": "Die Nische?",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "dialogue",
      "nl_text": "Diep genoeg. Ik bestel het hout maandag.",
      "ww_text": "Tief genug. Ich bestelle das Holz Montag.",
      "de_text": "Tief genug. Ich bestelle das Holz am Montag.",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Ein kurzes Schweigen."
    },
    {
      "scene_index": 5,
      "speaker": "JAN",
      "speaker_role": "character",
      "speaker_note": "leiser, als würde er etwas Praktisches erledigen",
      "type": "dialogue",
      "nl_text": "Haar verjaardag is over vier weken.",
      "ww_text": "Ihr Jahres·tag ist über vier Wochen.",
      "de_text": "Ihr Geburtstag ist in vier Wochen.",
      "has_reveal_button": true
    },
    {
      "scene_index": 5,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "dialogue",
      "nl_text": "Dat is genoeg tijd.",
      "ww_text": "Das ist genug Zeit.",
      "de_text": "Das ist genug Zeit.",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "JAN",
      "speaker_role": "character",
      "type": "dialogue",
      "nl_text": "Ik weet het. Maar toch.",
      "ww_text": "Ich weiß es. Aber trotzdem.",
      "de_text": "Ich weiß. Trotzdem.",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "dialogue",
      "nl_text": "Het wordt goed.",
      "ww_text": "Es wird gut.",
      "de_text": "Es wird gut.",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "JAN",
      "speaker_role": "character",
      "type": "dialogue",
      "nl_text": "Tot de volgende keer.",
      "ww_text": "Bis die nächste Mal.",
      "de_text": "Bis zum nächsten Mal.",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "dialogue",
      "nl_text": "Tot de volgende keer.",
      "ww_text": "Bis die nächste Mal.",
      "de_text": "Bis zum nächsten Mal.",
      "has_reveal_button": false
    },
    {
      "scene_index": 5,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Er geht zum Auto. Jan bleibt kurz im Türrahmen stehen. Dann schließt er die Tür."
    },
    {
      "scene_index": 6,
      "speaker": "ERZÄHLER",
      "speaker_role": "narrator",
      "type": "narrator_text",
      "de_text": "Die N325 nach Kleve. Die Straße, die er jetzt zweimal gefahren ist. Die Grenze irgendwo in der Mitte, fast unsichtbar.\n\nMarkus fährt.\n\nEr denkt an die Wandmaße in seinem Notizheft. An die Stärke des Lichts an diesem Morgen. An den abgegriffenen Wörterbuchrücken ganz unten im Regal – niederländisch-deutsch, die Ecken hochgebogen von langem Gebrauch.\n\nEr denkt an das, was sie gesagt hat.\n\n»Ik houd van boeken.«\n\nEr baut ihr ein Regal. Er hat sie heute zum ersten Mal gesehen."
    },
    {
      "scene_index": 6,
      "speaker": "MARKUS",
      "speaker_role": "protagonist",
      "type": "inner_monologue",
      "de_text": "Ein seltsamer Beruf, denkt er.\nMan baut Dinge für Menschen, die man kaum kennt."
    }
  ],
